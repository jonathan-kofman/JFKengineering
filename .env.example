# Canonical site URL for Open Graph and metadata (set on Vercel for production + previews).
# If unset: Vercel sets VERCEL_URL automatically; otherwise defaults to jfk-engineering.vercel.app.
# NEXT_PUBLIC_SITE_URL=https://your-custom-domain.com
#
# After changing OG setup, redeploy — preview URLs need the new /opengraph-image route or social previews 404.
